{
  "name": "supcontent-music",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "node scripts/dev-web-server.mjs",
    "build": "npm -ws run build"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "framer-motion": "^12.38.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
